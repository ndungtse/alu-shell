#!/usr/bin/env bash
# Init script to start, stop, or restart the manage_my_process daemon
PID_FILE="/var/run/my_process.pid"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"

case "$1" in
    start)
        nohup "$SCRIPT_DIR/manage_my_process" > /dev/null 2>&1 &
        echo $! > "$PID_FILE"
        echo "manage_my_process started"
        ;;
    stop)
        kill "$(cat "$PID_FILE")"
        rm -f "$PID_FILE"
        echo "manage_my_process stopped"
        ;;
    restart)
        kill "$(cat "$PID_FILE")"
        rm -f "$PID_FILE"
        nohup "$SCRIPT_DIR/manage_my_process" > /dev/null 2>&1 &
        echo $! > "$PID_FILE"
        echo "manage_my_process restarted"
        ;;
    *)
        echo "Usage: manage_my_process {start|stop|restart}"
        exit 1
        ;;
esac
